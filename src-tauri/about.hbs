<!doctype html>
<html lang="de">
<head>
<meta charset="utf-8">
<title>Klein.Buch — Drittanbieter-Bibliotheken</title>
<style>
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    max-width: 900px;
    margin: 2rem auto;
    padding: 0 1rem;
    color: #1a1a1a;
    line-height: 1.45;
  }
  h1 { font-size: 1.6rem; margin-bottom: 0.25rem; }
  h2 { font-size: 1.2rem; margin-top: 2rem; }
  .meta { color: #555; font-size: 0.9rem; margin-bottom: 2rem; }
  .lic { border: 1px solid #ddd; border-radius: 6px; padding: 1rem 1.25rem; margin: 0.75rem 0; background: #fafafa; }
  .lic h3 { margin: 0 0 0.25rem; font-size: 1rem; }
  .lic .spdx { color: #444; font-size: 0.85rem; margin-bottom: 0.5rem; }
  .lic ul { margin: 0.25rem 0 0; padding-left: 1.25rem; }
  .lic li { font-size: 0.85rem; }
  pre { background: #f4f4f4; padding: 1rem; overflow-x: auto; font-size: 0.8rem; border-radius: 4px; }
  .toc a { display: inline-block; margin: 0.1rem 0.4rem 0.1rem 0; font-size: 0.85rem; }
</style>
</head>
<body>
<h1>Klein.Buch — Drittanbieter-Bibliotheken (Rust)</h1>
<p class="meta">
  Erzeugt aus <code>Cargo.lock</code> per <a href="https://github.com/EmbarkStudios/cargo-about">cargo-about</a>.
  Pflicht-Hinweise zu Apache-2.0 (NOTICE) und GPL-Classpath-Exception (OpenJDK-Sidecar)
  stehen im „Über"-Dialog der App.
</p>

<div class="toc">
{{#each overview}}
  <a href="#{{id}}">{{name}}</a>
{{/each}}
</div>

{{#each licenses}}
<h2 id="{{id}}">{{name}} (SPDX: {{id}})</h2>
{{#each used_by}}
  <div class="lic">
    <h3>{{crate.name}} {{crate.version}}</h3>
    <div class="spdx">SPDX: {{crate.license}}</div>
    {{#if crate.description}}<div>{{crate.description}}</div>{{/if}}
    <ul>
      {{#if crate.repository}}<li>Repository: <code>{{crate.repository}}</code></li>{{/if}}
      {{#if crate.homepage}}<li>Homepage: <code>{{crate.homepage}}</code></li>{{/if}}
      {{#if crate.authors}}<li>Autoren: {{crate.authors}}</li>{{/if}}
    </ul>
  </div>
{{/each}}
<pre>{{text}}</pre>
{{/each}}

</body>
</html>
